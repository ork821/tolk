DOMAIN=your-domain.com

# Immutable backend image published by CI.
BACKEND_IMAGE=ghcr.io/your-account/tolk-api:1.0.0

# Absolute path containing the generated React SPA files.
FRONTEND_DIST_PATH=/var/www/tolk/current

JWT_ACCESS_SECRET=generate_very_long_random_string_here
JWT_REFRESH_TOKEN_HASH_SECRET=generate_another_very_long_random_string_here
# Secret from YooMoney wallet settings for HTTP notifications.
YOOMONEY_NOTIFICATION_SECRET=replace_with_yoomoney_notification_secret

# Private address of the database server. Do not use its public address.
DB_HOST=10.0.0.20
DB_PORT=55432
DB_NAME=tolk
APP_DB_USER=backend
APP_DB_PASSWORD=generate_backend_role_password

SSL_CERT_PATH=./nginx/ssl/server.crt
SSL_KEY_PATH=./nginx/ssl/server.key
