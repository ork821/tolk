# PostgreSQL listens only on this private interface.
DB_BIND_ADDRESS=10.0.0.20
DB_PORT=55432
DB_NAME=tolk

# Superuser credentials stay exclusively on the database server.
POSTGRES_PASSWORD=generate_strong_postgres_admin_password

# Must match the application server configuration.
APP_DB_USER=backend
APP_DB_PASSWORD=generate_backend_role_password
