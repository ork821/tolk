{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Properties": {
      "Application": "TolkApi"
    }
  },
  "FileLogging": {
    "Path": "logs/tolk-.log",
    "RetainedFileCountLimit": 30,
    "FileSizeLimitBytes": 104857600
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "JwtSettings": {
    "AccessSecret": "",
    "RefreshTokenHashSecret": ""
  },
  "YooMoney": {
    "NotificationSecret": ""
  },
  "ConnectionStrings": {
    "DataBase": ""
  },
  "PostReactionStatsSync": {
    "Enabled": true,
    "IntervalMinutes": 1,
    "BatchSize": 1000
  }
}
