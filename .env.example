# General
DOMAIN=your-domain.com

# Backend
JWT_ACCESS_SECRET=generate_very_long_random_string_here
NEXT_PUBLIC_VK_APP_ID=your_vk_id_app_id

# Database owner/superuser used only by postgres container initialization
POSTGRES_PASSWORD=generate_strong_postgres_admin_password

# Least-privilege application database role
APP_DB_USER=backend
APP_DB_PASSWORD=generate_backend_role_password

# Database host settings. For docker-compose.prod.yml, omit DB_HOST or set DB_HOST=db.
DB_HOST=db
DB_PORT=5432
DB_NAME=tolk

# SSL (Paths on the host machine)
SSL_CERT_PATH=./nginx/ssl/server.crt
SSL_KEY_PATH=./nginx/ssl/server.key
